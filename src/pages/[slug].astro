---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import RecipeView from "@/components/RecipeView.astro";
import { getRecipeImage } from "@/lib/utils";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes");

  return recipes.map((recipe) => ({
    params: { slug: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const image = await getRecipeImage(recipe.data.filePath);
---

<Layout>
  <RecipeView recipe={recipe.data} image={image} />
</Layout>
